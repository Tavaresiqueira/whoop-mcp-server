{
  "name": "whoop-mcp-server",
  "version": "1.0.0",
  "description": "Model Context Protocol server for WHOOP recovery, sleep, strain, and workout metrics.",
  "main": "dist/index.js",
  "bin": {
    "whoop-mcp-server": "dist/index.js",
    "whoop-mcp-login": "dist/login.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "login": "tsx src/login.ts",
    "setup": "tsx src/login.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "whoop",
    "mcp",
    "model-context-protocol"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
